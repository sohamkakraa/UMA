# PostgreSQL (Neon, Supabase, Railway, etc.). Required for sign-in and synced patient data.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
# Neon: use the *pooler* host (…-pooler.…) for DATABASE_URL and add pgbouncer=true + connect_timeout (cold start):
# DATABASE_URL="postgresql://…@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=30"
# Migrations use directUrl. Neon: non-pooler "direct" URI in DIRECT_URL; pooled URL in DATABASE_URL.
# Single host / Docker: copy the same value as DATABASE_URL.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Sign-in: HMAC for session cookie (min 16 chars). Required in production.
AUTH_SECRET=

# Google OAuth — enables "Continue with Google" on the login page (optional but recommended).
# Create credentials at: https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
# Set Application type to "Web application" and add Authorised redirect URIs:
#   https://your-domain.com/api/auth/google/callback
#   http://localhost:3000/api/auth/google/callback   (local dev)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend (https://resend.com): send real sign-in codes by email. Verified domain or onboarding@resend.dev for tests.
RESEND_API_KEY=
# From header. Until your domain is verified in Resend, use exactly:
# AUTH_EMAIL_FROM="UMA <onboarding@resend.dev>"
# Then switch to your domain, e.g. "UMA <noreply@yourdomain.com>"
AUTH_EMAIL_FROM=
# Set to 1 on the server to log only Resend error codes (not addresses) when sends fail.
AUTH_LOG_RESEND_ERRORS=
# Return OTP in API/UI after Send code: local dev, or Vercel Preview only (not Production).
# If RESEND_* is also set, email is tried first; on send failure Preview still returns devOtp when this is 1.
AUTH_DEV_RETURN_OTP=

# Optional shared beta / dummy account (email sign-in only). When both are set, "Send code" for this
# email stores this fixed 6-digit OTP instead of a random one (same verify flow as normal users).
# Share the email + OTP with testers privately. Rotate OTP or disable when the beta ends.
AUTH_BETA_DEMO_EMAIL=
AUTH_BETA_DEMO_OTP=
# If "1", the demo OTP is also returned in the request-otp JSON (easier for testers; do not use on public URLs).
AUTH_BETA_EXPOSE_DEMO_OTP=

# Required for PDF upload extraction (Claude reads the PDF via Messages API document block + structured JSON).
ANTHROPIC_API_KEY=
# Chat uses Claude when set (preferred). Optional OpenAI fallback below.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# Stronger default for PDF extraction (PDF-capable Sonnet). Override with ANTHROPIC_PDF_MODEL.
ANTHROPIC_PDF_MODEL=claude-sonnet-4-5-20250929
# Claude model used to structure text after LlamaParse OCR. Defaults to ANTHROPIC_MODEL (Haiku) if unset.
ANTHROPIC_STRUCTURE_MODEL=claude-haiku-4-5-20251001

# Optional: LlamaParse for faster, cheaper PDF OCR (https://cloud.llamaindex.ai).
# Free tier: 10,000 credits/month, 3 credits/page (~3,333 pages free/month).
# When set, extraction runs as two stages: LlamaParse OCR → Claude structures the text.
# This is significantly cheaper than Claude reading the full PDF directly.
# Falls back automatically to Claude full-PDF vision if LlamaParse returns HTTP 402
# (credits exhausted) or any other error — so it's safe to leave blank and add later.
LLAMA_CLOUD_API_KEY=

# Optional: chat fallback if ANTHROPIC_API_KEY is unset
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini

# ── WhatsApp Business Cloud API ──────────────────────────────────────────────
# Enables the /api/whatsapp/webhook endpoint so users can chat with UMA via WhatsApp.
# Setup: https://developers.facebook.com → your app → WhatsApp → Configuration
#
# WHATSAPP_VERIFY_TOKEN: any random secret you create (e.g. `openssl rand -hex 32`).
# Enter the SAME value in Meta Developer Console → Webhooks → Verify token.
WHATSAPP_VERIFY_TOKEN=
# WHATSAPP_ACCESS_TOKEN: permanent token from Meta Developer Console → WhatsApp → API Setup.
WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID: your WhatsApp Business phone number ID (numeric string).
WHATSAPP_PHONE_NUMBER_ID=
